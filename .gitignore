cat > .gitignore << 'EOF'
# Виртуальное окружение
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# База данных
db.sqlite3
*.sqlite3
*.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyz
*.pyzw
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
*.manifest
*.spec

# Django
*.log
*.pot
*.pyc
local_settings.py
.django-storage/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/
*.iml

# Системные файлы
.DS_Store
Thumbs.db
Desktop.ini

# Секреты
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# Логи
logs/
*.log

# Временные файлы
tmp/
temp/
*.tmp
EOF
